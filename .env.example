# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://botport:botport@localhost:5432/botport?schema=public"

# ─────────────────────────────────────────────────────────────
# Discord Application (https://discord.com/developers/applications)
# ─────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN=""
# Comma-separated guild IDs for fast command registration during dev (optional)
DISCORD_DEV_GUILD_IDS=""

# ─────────────────────────────────────────────────────────────
# Web / Auth
# ─────────────────────────────────────────────────────────────
# Public base URL of the dashboard (used for OAuth redirects & verify links)
APP_BASE_URL="http://localhost:3000"
# Secret used to sign session cookies — generate with: openssl rand -hex 32
AUTH_SECRET="change-me-please-openssl-rand-hex-32"

# ─────────────────────────────────────────────────────────────
# Cloudflare Turnstile (CAPTCHA) — https://developers.cloudflare.com/turnstile/
# Test keys below always pass; replace for production.
# ─────────────────────────────────────────────────────────────
TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
